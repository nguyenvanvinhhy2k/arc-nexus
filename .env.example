# ==============================================================================
# Arc Nexus - Environment Variables Template
# ==============================================================================

# 1. Circle Web3 AppKit Keys
# 👉 REQUIRED: Register an account at https://console.circle.com,
# then create a "Kit Key" under Developer Console -> API Keys.
# Paste your Kit Key here:
NEXT_PUBLIC_CIRCLE_KIT_KEY=KIT_KEY:c8f114fe028687059a34c600de9bfbef:644cda4d2f4de238edaa0da3f062f413

# 👉 OPTIONAL: Create a free Project ID at https://cloud.walletconnect.com
# to customize your wallet connection UI and branding.
# (If left empty, a default fallback key is used automatically).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=e596700f135b91b975e5330a108b98eb
DEPLOYER_PRIVATE_KEY=

# 2. RPC Providers for Testnets (Pre-filled by default)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app

NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://rpc.sepolia.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# 3. Stablecoin Token Contract Addresses on Arc Testnet (Pre-filled by default)
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
NEXT_PUBLIC_USYC_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C
NEXT_PUBLIC_CIRBTC_ADDRESS=0xf0C4a4CE82A5746AbAAd9425360Ab04fbBA432BF

# 4. Lend / Pool / Borrow Smart Contracts on Arc Testnet
# Use one shared contract address, or override each module with a dedicated address.
# Expected ABI:
# - lend(address asset, uint256 amount)
# - borrow(address asset, uint256 amount)
# - addLiquidity(address tokenA, address tokenB, uint256 amountA, uint256 amountB)

NEXT_PUBLIC_LEND_CONTRACT_ADDRESS=
NEXT_PUBLIC_POOL_CONTRACT_ADDRESS=
NEXT_PUBLIC_BORROW_CONTRACT_ADDRESS=
